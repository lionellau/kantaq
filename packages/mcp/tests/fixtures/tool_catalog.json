{
  "agent_action_approve": {
    "collections": [
      "agent_proposals",
      "tickets"
    ],
    "description": "Approve a pending agent proposal \u2014 apply its diff to the ticket through the one validated apply path. Requires tickets.write (an approver verb); an agent's propose-only scope can never reach it.",
    "input_schema": {
      "additionalProperties": false,
      "properties": {
        "proposal_id": {
          "maxLength": 26,
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "proposal_id"
      ],
      "type": "object"
    },
    "output_schema": {
      "properties": {
        "applied": {
          "const": true,
          "type": "boolean"
        },
        "proposal": {
          "properties": {
            "id": {
              "type": "string"
            },
            "status": {
              "enum": [
                "approved"
              ],
              "type": "string"
            },
            "ticket_id": {
              "type": "string"
            }
          },
          "required": [
            "id",
            "ticket_id",
            "status"
          ],
          "type": "object"
        },
        "ticket": {
          "properties": {
            "id": {
              "type": "string"
            },
            "lifecycle_stage": {
              "type": "string"
            },
            "status": {
              "type": "string"
            },
            "updated_at": {
              "type": "string"
            }
          },
          "required": [
            "id",
            "status",
            "lifecycle_stage",
            "updated_at"
          ],
          "type": "object"
        }
      },
      "required": [
        "proposal",
        "ticket",
        "applied"
      ],
      "type": "object"
    },
    "required_action": "tickets.write",
    "title": "Approve a proposal",
    "verb": "approve"
  },
  "agent_action_propose": {
    "collections": [
      "agent_proposals",
      "tickets"
    ],
    "description": "Propose a change to a ticket's fields. Stores a pending agent_proposal for human review in the Inbox; the ticket itself is NOT changed until a human approves.",
    "input_schema": {
      "additionalProperties": false,
      "properties": {
        "changes": {
          "description": "Proposed field changes, e.g. {\"status\": \"done\"}. Allowed fields: ['acceptance_criteria', 'assignee', 'description', 'due_date', 'labels', 'lifecycle_stage', 'parent_id', 'priority', 'status', 'title'].",
          "minProperties": 1,
          "type": "object"
        },
        "note": {
          "description": "Why the change is proposed; shown to the approver.",
          "maxLength": 2000,
          "type": "string"
        },
        "ticket_id": {
          "description": "The ticket's ULID.",
          "maxLength": 26,
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "ticket_id",
        "changes"
      ],
      "type": "object"
    },
    "output_schema": {
      "properties": {
        "applied": {
          "const": false,
          "description": "Proposals never change the ticket; a human applies them from the Inbox.",
          "type": "boolean"
        },
        "proposal": {
          "properties": {
            "created_at": {
              "type": "string"
            },
            "diff": {
              "properties": {
                "changes": {
                  "type": "object"
                },
                "note": {
                  "type": "string"
                }
              },
              "required": [
                "changes",
                "note"
              ],
              "type": "object"
            },
            "id": {
              "type": "string"
            },
            "proposer_id": {
              "type": "string"
            },
            "status": {
              "enum": [
                "pending"
              ],
              "type": "string"
            },
            "ticket_id": {
              "type": "string"
            }
          },
          "required": [
            "id",
            "ticket_id",
            "proposer_id",
            "status",
            "diff",
            "created_at"
          ],
          "type": "object"
        }
      },
      "required": [
        "proposal",
        "applied"
      ],
      "type": "object"
    },
    "required_action": "proposals.write",
    "title": "Propose a ticket change",
    "verb": "propose"
  },
