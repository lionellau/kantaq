# kantaq local runtime — team mode (shared Supabase). Copy to .env and fill in.
# The maintainer creates the Supabase project and shares the URL + anon key.
HUB_MODE=supabase
HOST=127.0.0.1
PORT=3939
LOCAL_DB_PATH=./data/local.sqlite
LOCAL_MCP_HOST=127.0.0.1
LOCAL_MCP_PORT=auto
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-key
# Never put the service-role key here. The client only uses the anon key.
