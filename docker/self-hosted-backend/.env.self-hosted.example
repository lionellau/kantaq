# kantaq self-hosted backend (HUB_MODE=postgres, MOD-28 / E25).
# Copy to `.env` in this directory, edit the password, then `docker compose up -d`.

# --- the Postgres the sync-server stores committed state in ---
POSTGRES_USER=kantaq
POSTGRES_PASSWORD=change-me-please-a-long-random-secret
POSTGRES_DB=kantaq

# --- the port the sync-server listens on (host side) ---
SYNC_PORT=8889

# --- optional HTTPS via the bundled Caddy (docker compose --profile tls up) ---
# A public hostname that resolves to this host (Caddy gets a Let's Encrypt cert).
CADDY_DOMAIN=kantaq.example.com

# ---------------------------------------------------------------------------
# Each teammate's *runtime* (not this server) then points at the server. Put
# these in the runtime's own .env (the machine running `kantaq`), NOT here:
#
#   HUB_MODE=postgres
#   HUB_URL=http://your-server-host:8889       # or https://kantaq.example.com behind Caddy
#   HUB_TOKEN=kq_<the member token the maintainer issued>
#
# The token is a normal kantaq member token (the same token/grant auth as
# Supabase mode — external OIDC is deferred, DEBT-14). Verify connectivity with:
#   kantaq sync status
# ---------------------------------------------------------------------------
